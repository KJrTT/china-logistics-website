# Формат: postgresql://username:password@host:port/database
# Получить можно в панели Render -> PostgreSQL -> Connection String
DATABASE_URL=postgresql://user:password@localhost:5432/logistic_db

# Для Gmail используйте App Password (не обычный пароль)
# Для других сервисов укажите свои настройки
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM=your_email@gmail.com
TO_EMAIL=manager@company.ru

# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your_secret_key_here_min_32_characters

# DEBUG=True для разработки, False для production
DEBUG=True

# Режим работы: dev / prod
ENVIRONMENT=dev

# URL фронтенда (для CORS)
FRONTEND_URL=http://localhost:3000

# Отправлять подтверждение пользователю (True/False)
SEND_CONFIRMATION_TO_USER=True

# Отправлять уведомление менеджеру (True/False)
SEND_NOTIFICATION_TO_MANAGER=True