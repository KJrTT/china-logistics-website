# Для локального PostgreSQL:
# postgresql://ИМЯ_ПОЛЬЗОВАТЕЛЯ:ПАРОЛЬ@localhost:5432/ИМЯ_БАЗЫ
#
# Для Render:
# Скопировать Connection String из панели Render -> PostgreSQL
# ------------------------------------------------------------
DATABASE_URL=postgresql://postgres:123456@localhost:5432/logistic_db


# Для Mail.ru:
#   SMTP_HOST=smtp.mail.ru
#   SMTP_PORT=465
#
# Для Gmail (нужен пароль приложения):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#
# Для Yandex:
#   SMTP_HOST=smtp.yandex.ru
#   SMTP_PORT=465
# ------------------------------------------------------------
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465

# SMTP_USER    - ваш email (отправитель)
# SMTP_PASSWORD - пароль от почты (для Mail.ru - обычный пароль,
#                 для Gmail - пароль приложения)
# SMTP_FROM    - тот же email, что и SMTP_USER
# ------------------------------------------------------------
SMTP_USER=your_email@yandex.ru
SMTP_PASSWORD=your_password
SMTP_FROM=your_email@yandex.ru

# Email менеджера или ваш email для теста
# ------------------------------------------------------------
TO_EMAIL=your_email@yandex.ru


# Сгенерировать новый ключ:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
# ------------------------------------------------------------
SECRET_KEY=dev_secret_key_1234567890

# DEBUG=True  - для разработки (подробные логи)
# DEBUG=False - для продакшена
# ------------------------------------------------------------
DEBUG=True
ENVIRONMENT=dev


# Локально: http://localhost:3000
# На Render: https://ваш-сайт.onrender.com
# ------------------------------------------------------------
FRONTEND_URL=http://localhost:3000

# SEND_CONFIRMATION_TO_USER   - отправлять подтверждение клиенту
# SEND_NOTIFICATION_TO_MANAGER - отправлять уведомление менеджеру
# ------------------------------------------------------------
SEND_CONFIRMATION_TO_USER=True
SEND_NOTIFICATION_TO_MANAGER=True